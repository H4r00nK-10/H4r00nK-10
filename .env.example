# Optional: if omitted, CivicLens AI uses demo-mode fallback intelligence.
OPENAI_API_KEY=

# Required when connecting Prisma to Supabase/PostgreSQL.
DATABASE_URL=

# Optional: override OpenStreetMap tiles for self-hosted/proxied tiles.
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
